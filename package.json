{
  "name": "pi-drykiss",
  "version": "0.1.2",
  "description": "Clear-context KISS/DRY reviewer subagents for Pi. Multi-lens code review that prioritizes quality over speed.",
  "type": "module",
  "license": "MIT",
  "author": "Apostolos Mantzaris",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R3LiC/pi-drykiss.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "code-review",
    "kiss",
    "dry",
    "simplicity",
    "refactor",
    "ai",
    "llm",
    "coding-assistant"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.ts",
    "src",
    "scripts/review-bench.ts",
    "fixtures/review-bench",
    "!src/**/*.test.ts",
    "!src/calibration-fixtures.ts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.scripts.json",
    "test": "vitest run",
    "lint": "eslint src/",
    "review:bench": "tsx scripts/review-bench.ts",
    "check:no-prompt-literals": "tsx scripts/check-no-prompt-literals.ts",
    "check:audit": "npm audit --audit-level=high --omit=dev",
    "check": "vitest run && tsc --noEmit && npm run check:audit && tsx scripts/check-no-prompt-literals.ts"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.49"
  },
  "peerDependencies": {
    "@earendil-works/pi-ai": ">=0.80.0",
    "@earendil-works/pi-coding-agent": ">=0.80.0",
    "@earendil-works/pi-tui": ">=0.80.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@vitest/coverage-v8": "^3.2.6",
    "tsx": "^4.23.0",
    "typescript": "^5.5.0",
    "vitest": "^3.2.6"
  }
}
