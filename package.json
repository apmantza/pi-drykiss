{
  "name": "pi-drykiss",
  "version": "0.1.2",
  "description": "Clear-context KISS/DRY reviewer subagents for Pi. Multi-lens code review that prioritizes quality over speed.",
  "type": "module",
  "license": "MIT",
  "author": "Apostolos Mantzaris",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/R3LiC/pi-drykiss.git"
  },
  "keywords": [
    "pi-package",
    "pi-extension",
    "pi-coding-agent",
    "code-review",
    "kiss",
    "dry",
    "simplicity",
    "refactor",
    "ai",
    "llm",
    "coding-assistant"
  ],
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.ts",
    "src",
    "!src/**/*.test.ts",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "lint": "eslint src/",
    "check": "vitest run && eslint src/ && tsc --noEmit"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": ">=0.74.0 <0.76.0",
    "@earendil-works/pi-ai": ">=0.74.0 <0.76.0",
    "@earendil-works/pi-tui": ">=0.74.0 <0.76.0"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-coding-agent": {
      "optional": true
    },
    "@earendil-works/pi-ai": {
      "optional": true
    },
    "@earendil-works/pi-tui": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
